{
  "manifest_version": 3,
  "name": "Minha Extensão React",
  "version": "1.0",
  "description": "Uma extensão do Chrome feita com React!",
  "permissions": ["scripting", "activeTab"],
  "background": {
    "service_worker": "./dist/background.js"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["./dist/content.js"],
      "type": "module"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["axe.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
